<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>SuperAdmin Dashboard</title>
  </head>
  <body>
    <h1>Dashboard</h1>
    <a href="/superadmin/pending">Pending Admin Requests</a>
    <h2>Pending Requests</h2>
    <ul>
      <% pending.forEach(function(p) { %>
        <li><%= p.adminId.email %> - <%= p.status %></li>
      <% }) %>
    </ul>
  </body>
</html>
